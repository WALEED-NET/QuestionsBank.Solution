@page "/lessons/create"
@page "/lessons/edit/{Id:guid}"
@layout AppLayout
@rendermode InteractiveServer
@using Blazorise
@implements IDisposable
@inject LessonService LessonService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<Container Fluid Class="py-3">
    <!-- Header Section -->
    <Div Class="d-flex justify-content-between align-items-center mb-4">
        <Div>
            <Heading Size="HeadingSize.Is4" Margin="Margin.Is0">
                <i class="fas @(IsEdit ? "fa-edit" : "fa-plus") me-2 text-primary"></i>
                @(IsEdit ? "تعديل الدرس" : "إضافة درس جديد")
            </Heading>
            <Small Class="text-muted">@(IsEdit ? "قم بتعديل بيانات الدرس" : "أدخل بيانات الدرس الجديد")</Small>
        </Div>
        <Button Color="Color.Light" Clicked="GoBack">
            <i class="fas fa-arrow-right me-2"></i>
            العودة للقائمة
        </Button>
    </Div>

    <!-- Tabs Navigation -->
    <Tabs @bind-SelectedTab="selectedTab" Pills FullWidth Class="lesson-tabs mb-4">
        <Items>
            <Tab Name="lesson">
                <i class="fas fa-book me-2"></i>
                بيانات الدرس
            </Tab>
            <Tab Name="topics">
                <i class="fas fa-layer-group me-2"></i>
                المواضيع
                @if (lesson.Topics.Any())
                {
                    <Badge Color="Color.Success" Class="ms-2">@lesson.Topics.Count</Badge>
                }
            </Tab>
            <Tab Name="questions">
                <i class="fas fa-question-circle me-2"></i>
                بنك الأسئلة
                @if (lesson.Questions.Any())
                {
                    <Badge Style="background: #f97316;" Class="ms-2">@lesson.Questions.Count</Badge>
                }
            </Tab>
        </Items>
        <Content>
            <!-- Tab 1: بيانات الدرس -->
            <TabPanel Name="lesson" Class="pt-4">
                <Card Class="shadow-sm">
                    <CardHeader Background="Background.Primary" TextColor="TextColor.White">
                        <i class="fas fa-info-circle me-2"></i>
                        المعلومات الأساسية
                    </CardHeader>
                    <CardBody>
                        <Row Class="g-3">
                            <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnDesktop">
                                <Field>
                                    <FieldLabel>اسم الدرس *</FieldLabel>
                                    <input type="text" class="form-control" @bind="lesson.Name"
                                           placeholder="أدخل اسم الدرس" />
                                </Field>
                            </Column>
                            <Column ColumnSize="ColumnSize.Is12.OnMobile.Is3.OnDesktop">
                                <Field>
                                    <FieldLabel>الوحدة *</FieldLabel>
                                    <Select TValue="int" @bind-SelectedValue="lesson.UnitId"
                                            @bind-SelectedValue:after="OnUnitChangedAfter">
                                        <SelectItem TValue="int" Value="0">اختر الوحدة</SelectItem>
                                        @foreach (var unit in Units.GetAll())
                                        {
                                            <SelectItem TValue="int" Value="@unit.Id">@unit.Name</SelectItem>
                                        }
                                    </Select>
                                </Field>
                            </Column>
                            <Column ColumnSize="ColumnSize.Is12.OnMobile.Is3.OnDesktop">
                                <Field>
                                    <FieldLabel>الترتيب</FieldLabel>
                                    <input type="number" class="form-control" @bind="lesson.Order" min="1" />
                                </Field>
                            </Column>
                        </Row>
                        
                        <Row Class="g-3 mt-2">
                            <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnDesktop">
                                <Field>
                                    <FieldLabel>المقدمة</FieldLabel>
                                    <textarea class="form-control" @bind="lesson.Introduction" rows="3"
                                              placeholder="مقدمة الدرس..."></textarea>
                                </Field>
                            </Column>
                            <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnDesktop">
                                <Field>
                                    <FieldLabel>الأهداف</FieldLabel>
                                    <textarea class="form-control" @bind="lesson.Goals" rows="3"
                                              placeholder="أهداف الدرس..."></textarea>
                                </Field>
                            </Column>
                        </Row>
                        
                        <Row Class="g-3 mt-2">
                            <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnDesktop">
                                <Field>
                                    <FieldLabel>رابط الصوت</FieldLabel>
                                    <input type="url" class="form-control" @bind="lesson.AudioUrl"
                                           placeholder="https://..." />
                                </Field>
                            </Column>
                            <Column ColumnSize="ColumnSize.Is12.OnMobile.Is3.OnDesktop">
                                <Field>
                                    <FieldLabel>الحالة</FieldLabel>
                                    <Select TValue="bool" @bind-SelectedValue="lesson.IsActive">
                                        <SelectItem TValue="bool" Value="true">نشط</SelectItem>
                                        <SelectItem TValue="bool" Value="false">غير نشط</SelectItem>
                                    </Select>
                                </Field>
                            </Column>
                        </Row>
                    </CardBody>
                </Card>
            </TabPanel>

            <!-- Tab 2: المواضيع -->
            <TabPanel Name="topics" Class="pt-4">
                <Card Class="shadow-sm">
                    <CardHeader Background="Background.Success" TextColor="TextColor.White">
                        <Div Class="d-flex justify-content-between align-items-center">
                            <Span>
                                <i class="fas fa-layer-group me-2"></i>
                                المواضيع (@lesson.Topics.Count)
                            </Span>
                            <Button Color="Color.Light" Size="Size.Small" Clicked="ShowAddTopicForm"
                                    Disabled="showTopicForm">
                                <i class="fas fa-plus me-1"></i>
                                إضافة موضوع
                            </Button>
                        </Div>
                    </CardHeader>
                    <CardBody>
                        <!-- جدول المواضيع -->
                        @if (lesson.Topics.Any())
                        {
                            <div class="table-responsive mb-3">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 40px;"></th>
                                            <th style="width: 50px;">#</th>
                                            <th>اسم الموضوع</th>
                                            <th>الوصف</th>
                                            <th class="text-center" style="width: 100px;">المحتوى</th>
                                            <th class="text-center" style="width: 100px;">الأسئلة</th>
                                            <th class="text-center" style="width: 70px;">الحالة</th>
                                            <th class="text-center" style="width: 120px;">الإجراءات</th>
                                        </tr>
                                    </thead>
                                    <tbody id="topics-sortable">
                                        @foreach (var (topic, index) in lesson.Topics.OrderBy(t => t.Order).Select((t, i) =>
                                                                            (t, i + 1)))
                                        {
                                            <tr class="topic-row @(selectedTopicId == topic.Id ? "table-active" : "")"
                                                data-id="@topic.Id">
                                                <td class="drag-handle text-center" style="cursor: grab;">
                                                    <i class="fas fa-grip-vertical text-muted"></i>
                                                </td>
                                                <td>@index</td>
                                                <td @onclick="@(() => ToggleTopicDetails(topic.Id))" style="cursor: pointer;">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <i
                                                        class="fas @(selectedTopicId == topic.Id ? "fa-chevron-down" : "fa-chevron-left") text-muted small"></i>
                                                        <strong>@(string.IsNullOrEmpty(topic.Name) ? "بدون اسم" :
                                                                                                                topic.Name)</strong>
                                                        </div>
                                                    </td>
                                                    <td class="text-muted small">@(topic.Description?.Truncate(30) ?? "-")</td>
                                                    <td class="text-center">
                                                        <button type="button"
                                                                class="btn btn-sm @(topic.Contents.Any() ? "btn-primary" : "btn-outline-primary")"
                                                                @onclick="@(() => QuickAddContent(topic))" title="إضافة محتوى">
                                                            <i class="fas fa-file-alt me-1"></i>
                                                            @topic.Contents.Count
                                                            <i class="fas fa-plus-circle ms-1 small"></i>
                                                        </button>
                                                    </td>
                                                    <td class="text-center">
                                                        <button type="button"
                                                                class="btn btn-sm @(topic.Questions.Any() ? "btn-warning" : "btn-outline-warning")"
                                                                style="@(topic.Questions.Any() ? "background: #f97316; border-color: #f97316;" : "color: #f97316; border-color: #f97316;")"
                                                                @onclick="@(() => QuickAddTopicQuestion(topic))" title="إضافة سؤال">
                                                            <i class="fas fa-question-circle me-1"></i>
                                                            @topic.Questions.Count
                                                            <i class="fas fa-plus-circle ms-1 small"></i>
                                                        </button>
                                                    </td>
                                                    <td class="text-center">
                                                        @if (topic.IsActive)
                                                        {
                                                            <Badge Color="Color.Success">نشط</Badge>
                                                        }
                                                        else
                                                        {
                                                            <Badge Color="Color.Secondary">معطل</Badge>
                                                        }
                                                    </td>
                                                    <td class="text-center">
                                                        <Buttons Size="Size.Small">
                                                            <Button Color="Color.Primary" Outline
                                                                    Clicked="@(() => EditTopic(topic))" title="تعديل">
                                                                <i class="fas fa-edit"></i>
                                                            </Button>
                                                            <Button Color="Color.Danger" Outline
                                                                    Clicked="@(() => RemoveTopic(topic))" title="حذف">
                                                                <i class="fas fa-trash"></i>
                                                            </Button>
                                                        </Buttons>
                                                    </td>
                                                </tr>
                                                @if (selectedTopicId == topic.Id)
                                                {
                                                    <tr>
                                                        <td colspan="8" class="p-0 border-0">
                                                            <div class="bg-light p-3">
                                                                <!-- المحتوى -->
                                                                <Card Class="mb-3" Style="border-right: 3px solid #a855f7;">
                                                                    <CardHeader Style="background: #faf5ff;">
                                                                        <Div Class="d-flex justify-content-between align-items-center">
                                                                            <Span Style="color: #7c3aed;">
                                                                                <i class="fas fa-file-alt me-2"></i>
                                                                                المحتوى (@topic.Contents.Count)
                                                                            </Span>
                                                                            <Button Color="Color.Primary" Size="Size.Small" Outline
                                                                                    Clicked="@(() => ShowAddContentForm(topic))"
                                                                                    Disabled="@(showContentFormForTopic == topic.Id)">
                                                                                <i class="fas fa-plus"></i>
                                                                            </Button>
                                                                        </Div>
                                                                    </CardHeader>
                                                                    <CardBody>
                                                                        @if (topic.Contents.Any())
                                                                        {
                                                                            <table class="table table-sm table-hover mb-3">
                                                                                <thead class="table-light">
                                                                                    <tr>
                                                                                        <th style="width: 35px;"></th>
                                                                                        <th style="width: 35px;">#</th>
                                                                                        <th>العنوان</th>
                                                                                        <th>المحتوى</th>
                                                                                        <th class="text-center" style="width: 70px;">الحالة
                                                                                        </th>
                                                                                        <th class="text-center" style="width: 100px;">
                                                                                            الإجراءات</th>
                                                                                        </tr>
                                                                                    </thead>
                                                                                    <tbody id="content-sortable-@topic.Id">
                                                                                        @foreach (var (content, cIdx) in
                                                                                                                                                        topic.Contents.OrderBy(c => c.Order).Select((c, i) =>
                                                                                                                                                        (c, i + 1)))
                                                                                        {
                                                                                            <tr data-id="@content.Id" data-topic-id="@topic.Id">
                                                                                                <td class="drag-handle text-center">
                                                                                                    <i class="fas fa-grip-vertical text-muted"></i>
                                                                                                </td>
                                                                                                <td>@cIdx</td>
                                                                                                <td>@(string.IsNullOrEmpty(content.Title) ? "-" :
                                                                                                                                                                            content.Title)</td>
                                                                                                    <td class="text-muted small">
                                                                                                        @(content.Body?.Truncate(40) ?? "-")</td>
                                                                                                        <td class="text-center">
                                                                                                            @if (content.IsActive)
                                                                                                            {
                                                                                                                <Badge Color="Color.Success" Class="badge-sm">
                                                                                                                    نشط</Badge>
                                                                                                                }
                                                                                            else
                                                                                                                {
                                                                                                                    <Badge Color="Color.Secondary" Class="badge-sm">
                                                                                                                        معطل</Badge>
                                                                                                                    }
                                                                                                                </td>
                                                                                                                <td class="text-center">
                                                                                                                    <Buttons Size="Size.Small">
                                                                                                                        <Button Color="Color.Primary" Outline
                                                                                                                                Clicked="@(() => EditContent(topic, content))">
                                                                                                                            <i class="fas fa-edit"></i>
                                                                                                                        </Button>
                                                                                                                        <Button Color="Color.Danger" Outline
                                                                                                                                Clicked="@(() => RemoveContent(topic, content))">
                                                                                                                            <i class="fas fa-trash"></i>
                                                                                                                        </Button>
                                                                                                                    </Buttons>
                                                                                                                </td>
                                                                                                            </tr>
                                                                                                        }
                                                                                                    </tbody>
                                                                                                </table>
                                                                                            }
                                                                    
                                                                                            @if (showContentFormForTopic == topic.Id)
                                                                                            {
                                                                                                <Card Class="border-primary">
                                                                                                    <CardBody>
                                                                                                        <Row Class="g-2">
                                                                                                            <Column
                                                                                                                ColumnSize="ColumnSize.Is12.OnMobile.Is4.OnDesktop">
                                                                                                                <Field>
                                                                                                                    <FieldLabel>العنوان *</FieldLabel>
                                                                                                                    <input type="text"
                                                                                                                           class="form-control form-control-sm"
                                                                                                                           @bind="contentFormData.Title"
                                                                                                                           placeholder="عنوان المحتوى" />
                                                                                                                </Field>
                                                                                                            </Column>
                                                                                                            <Column
                                                                                                                ColumnSize="ColumnSize.Is12.OnMobile.Is8.OnDesktop">
                                                                                                                <Field>
                                                                                                                    <FieldLabel>النص</FieldLabel>
                                                                                                                    <textarea
                                                                                                                    class="form-control form-control-sm"
                                                                                                                    @bind="contentFormData.Body" rows="2"
                                                                                                                    placeholder="نص المحتوى..."></textarea>
                                                                                                                </Field>
                                                                                                            </Column>
                                                                                                        </Row>
                                                                                                        <Row Class="g-2 mt-2">
                                                                                                            <Column
                                                                                                                ColumnSize="ColumnSize.Is12.OnMobile.Is4.OnDesktop">
                                                                                                                <Field>
                                                                                                                    <FieldLabel>رابط الفيديو</FieldLabel>
                                                                                                                    <input type="url"
                                                                                                                           class="form-control form-control-sm"
                                                                                                                           @bind="contentFormData.VideoUrl"
                                                                                                                           placeholder="https://..." />
                                                                                                                </Field>
                                                                                                            </Column>
                                                                                                            <Column
                                                                                                                ColumnSize="ColumnSize.Is12.OnMobile.Is4.OnDesktop">
                                                                                                                <Field>
                                                                                                                    <FieldLabel>رابط الصوت</FieldLabel>
                                                                                                                    <input type="url"
                                                                                                                           class="form-control form-control-sm"
                                                                                                                           @bind="contentFormData.AudioUrl"
                                                                                                                           placeholder="https://..." />
                                                                                                                </Field>
                                                                                                            </Column>
                                                                                                            <Column
                                                                                                                ColumnSize="ColumnSize.Is6.OnMobile.Is2.OnDesktop">
                                                                                                                <Field>
                                                                                                                    <FieldLabel>نشط</FieldLabel>
                                                                                                                    <Check TValue="bool"
                                                                                                                           @bind-Checked="contentFormData.IsActive">
                                                                                                                        نعم</Check>
                                                                                                                    </Field>
                                                                                                                </Column>
                                                                                                                <Column
                                                                                                                    ColumnSize="ColumnSize.Is6.OnMobile.Is2.OnDesktop"
                                                                                                                    Class="d-flex align-items-end">
                                                                                                                    <Buttons Size="Size.Small">
                                                                                                                        <Button Color="Color.Success"
                                                                                                                                Clicked="@(() => SaveContent(topic))">
                                                                                                                            <i class="fas fa-check me-1"></i> حفظ
                                                                                                                        </Button>
                                                                                                                        <Button Color="Color.Light"
                                                                                                                                Clicked="CancelContentForm">
                                                                                                                            <i class="fas fa-times"></i>
                                                                                                                        </Button>
                                                                                                                    </Buttons>
                                                                                                                </Column>
                                                                                                            </Row>
                                                                                                        </CardBody>
                                                                                                    </Card>
                                                                                                }
                                                                    else if (!topic.Contents.Any())
                                                                                                {
                                                                                                    <small class="text-muted">لا يوجد محتوى</small>
                                                                                                }
                                                                                            </CardBody>
                                                                                        </Card>

                                                                                        <!-- أسئلة الموضوع -->
                                                                                        <Card Style="border-right: 3px solid var(--orange-500);">
                                                                                            <CardHeader Style="background: var(--orange-50);">
                                                                                                <Div Class="d-flex justify-content-between align-items-center">
                                                                                                    <Span Style="color: var(--orange-700);">
                                                                                                        <i class="fas fa-question-circle me-2"></i>
                                                                                                        أسئلة الموضوع (@topic.Questions.Count)
                                                                                                    </Span>
                                                                                                    <Button Size="Size.Small"
                                                                                                            Style="border-color: var(--orange-500); color: var(--orange-500);"
                                                                                                            Clicked="@(() => ShowAddTopicQuestionForm(topic))"
                                                                                                            Disabled="@(showQuestionFormForTopic == topic.Id)">
                                                                                                        <i class="fas fa-plus"></i>
                                                                                                    </Button>
                                                                                                </Div>
                                                                                            </CardHeader>
                                                                                            <CardBody>
                                                                                                @if (topic.Questions.Any())
                                                                                                {
                                                                                                    <table class="table table-sm table-hover mb-3">
                                                                                                        <thead class="table-light">
                                                                                                            <tr>
                                                                                                                <th style="width: 35px;"></th>
                                                                                                                <th style="width: 35px;">#</th>
                                                                                                                <th>نص السؤال</th>
                                                                                                                <th class="text-center" style="width: 100px;">النوع
                                                                                                                </th>
                                                                                                                <th class="text-center" style="width: 100px;">
                                                                                                                    الإجراءات</th>
                                                                                                                </tr>
                                                                                                            </thead>
                                                                                                            <tbody id="topic-questions-sortable-@topic.Id">
                                                                                                                @foreach (var (question, qIdx) in
                                                                                                                                                                                topic.Questions.OrderBy(q => q.Order).Select((q, i) =>
                                                                                                                                                                                (q, i + 1)))
                                                                                                                {
                                                                                                                    <tr data-id="@question.Id" data-topic-id="@topic.Id">
                                                                                                                        <td class="drag-handle text-center">
                                                                                                                            <i class="fas fa-grip-vertical text-muted"></i>
                                                                                                                        </td>
                                                                                                                        <td>@qIdx</td>
                                                                                                                        <td>@(string.IsNullOrEmpty(question.Text) ? "-" :
                                                                                                                                                                                                    question.Text.Truncate(40))</td>
                                                                                                                            <td class="text-center">
                                                                                                                                <Badge
                                                                                                                                    Color="@GetQuestionTypeBadgeColor(question.Type)"
                                                                                                                                    Class="badge-sm">
                                                                                                                                    @GetQuestionTypeLabel(question.Type)
                                                                                                                                </Badge>
                                                                                                                            </td>
                                                                                                                            <td class="text-center">
                                                                                                                                <Buttons Size="Size.Small">
                                                                                                                                    <Button Color="Color.Primary" Outline
                                                                                                                                            Clicked="@(() => EditTopicQuestion(topic, question))">
                                                                                                                                        <i class="fas fa-edit"></i>
                                                                                                                                    </Button>
                                                                                                                                    <Button Color="Color.Danger" Outline
                                                                                                                                            Clicked="@(() => RemoveQuestion(topic.Questions, question))">
                                                                                                                                        <i class="fas fa-trash"></i>
                                                                                                                                    </Button>
                                                                                                                                </Buttons>
                                                                                                                            </td>
                                                                                                                        </tr>
                                                                                                                    }
                                                                                                                </tbody>
                                                                                                            </table>
                                                                                                        }
                                                                    
                                                                                                        @if (showQuestionFormForTopic == topic.Id)
                                                                                                        {
                                                                                                            <QuestionEditor Question="GetTopicQuestionFormData(topic)"
                                                                                                                            Index="0" OnRemove="@(() => CancelTopicQuestionForm())"
                                                                                                                            ShowSaveCancel="true"
                                                                                                                            OnSave="@(() => SaveTopicQuestion(topic))"
                                                                                                                            OnCancel="@(() => CancelTopicQuestionForm())"
                                                                                                                            IsEditMode="@(editingTopicQuestion != null)" />
                                                                                                        }
                                                                                                        else if (!topic.Questions.Any())
                                                                                                        {
                                                                                                            <small class="text-muted">لا توجد أسئلة</small>
                                                                                                        }
                                                                                                    </CardBody>
                                                                                                </Card>
                                                                                            </div>
                                                                                        </td>
                                                                                    </tr>
                                                                                }
                                                                            }
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            }
                        else if (!showTopicForm)
                                                            {
                                                                <Alert Color="Color.Info" Visible>
                                                                    <i class="fas fa-info-circle me-2"></i>
                                                                    لا توجد مواضيع. اضغط على "إضافة موضوع" لإضافة موضوع جديد.
                                                                </Alert>
                                                            }

                                                            <!-- نموذج إضافة/تعديل موضوع -->
                                                            @if (showTopicForm)
                                                            {
                                                                <Card Style="border-right: 3px solid #22c55e;" Class="mt-3">
                                                                    <CardHeader Style="background: #f0fdf4;">
                                                                        <Div Class="d-flex justify-content-between align-items-center">
                                                                            <Span Style="color: #16a34a;">
                                                                                <i class="fas @(editingTopic != null ? "fa-edit" : "fa-plus") me-2"></i>
                                                                                @(editingTopic != null ? "تعديل الموضوع" : "إضافة موضوع جديد")
                                                                            </Span>
                                                                            <Button Color="Color.Light" Size="Size.Small" Clicked="CancelTopicForm">
                                                                                <i class="fas fa-times"></i>
                                                                            </Button>
                                                                        </Div>
                                                                    </CardHeader>
                                                                    <CardBody>
                                                                        <Row Class="g-3">
                                                                            <Column ColumnSize="ColumnSize.Is12.OnMobile.Is5.OnDesktop">
                                                                                <Field>
                                                                                    <FieldLabel>اسم الموضوع *</FieldLabel>
                                                                                    <input type="text" class="form-control" @bind="topicFormData.Name"
                                                                                           placeholder="أدخل اسم الموضوع" />
                                                                                </Field>
                                                                            </Column>
                                                                            <Column ColumnSize="ColumnSize.Is12.OnMobile.Is4.OnDesktop">
                                                                                <Field>
                                                                                    <FieldLabel>الوصف</FieldLabel>
                                                                                    <input type="text" class="form-control" @bind="topicFormData.Description"
                                                                                           placeholder="وصف مختصر" />
                                                                                </Field>
                                                                            </Column>
                                                                            <Column ColumnSize="ColumnSize.Is6.OnMobile.Is2.OnDesktop">
                                                                                <Field>
                                                                                    <FieldLabel>الترتيب</FieldLabel>
                                                                                    <input type="number" class="form-control" @bind="topicFormData.Order"
                                                                                           min="1" />
                                                                                </Field>
                                                                            </Column>
                                                                            <Column ColumnSize="ColumnSize.Is6.OnMobile.Is1.OnDesktop">
                                                                                <Field>
                                                                                    <FieldLabel>نشط</FieldLabel>
                                                                                    <Check TValue="bool" @bind-Checked="topicFormData.IsActive">نعم</Check>
                                                                                </Field>
                                                                            </Column>
                                                                        </Row>
                                                                        <Row Class="g-3 mt-2">
                                                                            <Column ColumnSize="ColumnSize.Is12.OnMobile.Is6.OnDesktop">
                                                                                <Field>
                                                                                    <FieldLabel>رابط الصوت</FieldLabel>
                                                                                    <input type="url" class="form-control" @bind="topicFormData.AudioUrl"
                                                                                           placeholder="https://..." />
                                                                                </Field>
                                                                            </Column>
                                                                        </Row>
                                                                        <Div Class="d-flex justify-content-end gap-2 mt-3">
                                                                            <Button Color="Color.Light" Clicked="CancelTopicForm">
                                                                                <i class="fas fa-times me-1"></i>
                                                                                إلغاء
                                                                            </Button>
                                                                            <Button Color="Color.Success" Clicked="SaveTopic">
                                                                                <i class="fas fa-check me-1"></i>
                                                                                @(editingTopic != null ? "حفظ التعديلات" : "إضافة")
                                                                            </Button>
                                                                        </Div>
                                                                    </CardBody>
                                                                </Card>
                                                            }
                                                        </CardBody>
                                                    </Card>
                                                </TabPanel>

                                                <!-- Tab 3: بنك الأسئلة -->
                                                <TabPanel Name="questions" Class="pt-4">
                                                    <Card Class="shadow-sm">
                                                        <CardHeader Style="background: #f97316; color: white;">
                                                            <Div Class="d-flex justify-content-between align-items-center">
                                                                <Span>
                                                                    <i class="fas fa-question-circle me-2"></i>
                                                                    بنك الأسئلة - أسئلة الدرس (@lesson.Questions.Count)
                                                                </Span>
                                                                <Button Color="Color.Light" Size="Size.Small" Clicked="ShowAddLessonQuestionForm"
                                                                        Disabled="showLessonQuestionForm">
                                                                    <i class="fas fa-plus me-1"></i>
                                                                    إضافة سؤال
                                                                </Button>
                                                            </Div>
                                                        </CardHeader>
                                                        <CardBody>
                                                            <Alert Color="Color.Warning" Visible Class="mb-3">
                                                                <i class="fas fa-info-circle me-2"></i>
                                                                هذه الأسئلة مرتبطة بالدرس مباشرة. لإضافة أسئلة لموضوع معين، اذهب لتاب "المواضيع".
                                                            </Alert>
                        
                                                            @if (lesson.Questions.Any())
                                                            {
                                                                <div class="table-responsive mb-3">
                                                                    <table class="table table-hover align-middle mb-0">
                                                                        <thead class="table-light">
                                                                            <tr>
                                                                                <th style="width: 40px;"></th>
                                                                                <th style="width: 50px;">#</th>
                                                                                <th>نص السؤال</th>
                                                                                <th class="text-center" style="width: 120px;">النوع</th>
                                                                                <th class="text-center" style="width: 80px;">النقاط</th>
                                                                                <th class="text-center" style="width: 70px;">الحالة</th>
                                                                                <th class="text-center" style="width: 120px;">الإجراءات</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody id="lesson-questions-sortable">
                                                                            @foreach (var (question, index) in lesson.Questions.OrderBy(q => q.Order).Select((q,
                                                                                                                i) => (q, i + 1)))
                                                                            {
                                                                                <tr data-id="@question.Id">
                                                                                    <td class="drag-handle text-center" style="cursor: grab;">
                                                                                        <i class="fas fa-grip-vertical text-muted"></i>
                                                                                    </td>
                                                                                    <td>@index</td>
                                                                                    <td>@(string.IsNullOrEmpty(question.Text) ? "-" : question.Text.Truncate(50))
                                                                                    </td>
                                                                                    <td class="text-center">
                                                                                        <Badge Color="@GetQuestionTypeBadgeColor(question.Type)">
                                                                                            @GetQuestionTypeLabel(question.Type)
                                                                                        </Badge>
                                                                                    </td>
                                                                                    <td class="text-center">@question.Points</td>
                                                                                    <td class="text-center">
                                                                                        @if (question.IsActive)
                                                                                        {
                                                                                            <Badge Color="Color.Success">نشط</Badge>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <Badge Color="Color.Secondary">معطل</Badge>
                                                                                        }
                                                                                    </td>
                                                                                    <td class="text-center">
                                                                                        <Buttons Size="Size.Small">
                                                                                            <Button Color="Color.Primary" Outline
                                                                                                    Clicked="@(() => EditLessonQuestion(question))" title="تعديل">
                                                                                                <i class="fas fa-edit"></i>
                                                                                            </Button>
                                                                                            <Button Color="Color.Danger" Outline
                                                                                                    Clicked="@(() => RemoveQuestion(lesson.Questions, question))"
                                                                                                    title="حذف">
                                                                                                <i class="fas fa-trash"></i>
                                                                                            </Button>
                                                                                        </Buttons>
                                                                                    </td>
                                                                                </tr>
                                                                            }
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            }
                                                            else if (!showLessonQuestionForm)
                                                            {
                                                                <Alert Color="Color.Info" Visible>
                                                                    <i class="fas fa-info-circle me-2"></i>
                                                                    لا توجد أسئلة مرتبطة بالدرس مباشرة.
                                                                </Alert>
                                                            }

                                                            @if (showLessonQuestionForm)
                                                            {
                                                                <QuestionEditor Question="lessonQuestionFormData" Index="0" OnRemove="CancelLessonQuestionForm"
                                                                                ShowSaveCancel="true" OnSave="SaveLessonQuestion" OnCancel="CancelLessonQuestionForm"
                                                                                IsEditMode="@(editingLessonQuestion != null)" />
                                                            }
                                                        </CardBody>
                                                    </Card>
                                                </TabPanel>
                                            </Content>
                                        </Tabs>

                                        <!-- Action Buttons -->
                                        <Card Class="shadow-sm mt-4">
                                            <CardBody>
                                                <Div Class="d-flex justify-content-between">
                                                    <Button Color="Color.Light" Clicked="GoBack">
                                                        <i class="fas fa-times me-1"></i>
                                                        إلغاء
                                                    </Button>
                                                    <Div>
                                                        <Button Color="Color.Primary" Clicked="SaveLesson" Class="me-2">
                                                            <i class="fas fa-save me-1"></i>
                                                            @(IsEdit ? "حفظ التغييرات" : "حفظ الدرس")
                                                        </Button>
                                                        @if (!IsEdit)
                                                        {
                                                            <Button Color="Color.Success" Clicked="SaveAndAddNew">
                                                                <i class="fas fa-plus me-1"></i>
                                                                حفظ وإضافة جديد
                                                            </Button>
                                                        }
                                                    </Div>
                                                </Div>
                                            </CardBody>
                                        </Card>
                                    </Container>

@code {
    [Parameter] public Guid? Id { get; set; }

    private Lesson lesson = new();
    private bool IsEdit => Id.HasValue;
    private string selectedTab = "lesson";
    
    // Topic form
    private bool showTopicForm = false;
    private Topic? editingTopic = null;
    private Topic topicFormData = new();
    private Guid? selectedTopicId = null;
    
    // Content form
    private Guid? showContentFormForTopic = null;
    private Content? editingContent = null;
    private Content contentFormData = new();
    
    // Topic Question form
    private Guid? showQuestionFormForTopic = null;
    private Question? editingTopicQuestion = null;
    private Dictionary<Guid, Question> topicQuestionFormData = new();
    
    // Lesson Question form
    private bool showLessonQuestionForm = false;
    private Question? editingLessonQuestion = null;
    private Question lessonQuestionFormData = new();

    protected override void OnInitialized()
    {
        if (IsEdit && Id.HasValue)
        {
            var existingLesson = LessonService.GetById(Id.Value);
            if (existingLesson != null)
            {
                lesson = existingLesson;
            }
            else
            {
                NavigationManager.NavigateTo("/lessons");
            }
        }
        
        InitializeQuestionFormData();
    }
    
    private void InitializeQuestionFormData()
    {
        lessonQuestionFormData = CreateNewQuestion();
    }
    
    private Question CreateNewQuestion()
    {
        var question = new Question();
        question.Options.Add(new QuestionOption { Text = "", Order = 1 });
        question.Options.Add(new QuestionOption { Text = "", Order = 2 });
        question.Options.Add(new QuestionOption { Text = "", Order = 3 });
        question.Options.Add(new QuestionOption { Text = "", Order = 4 });
        return question;
    }

    private void OnUnitChangedAfter()
    {
        var unit = Units.GetAll().FirstOrDefault(u => u.Id == lesson.UnitId);
        lesson.UnitName = unit.Name ?? "";
    }

    #region Topic Methods
    
    private void ShowAddTopicForm()
    {
        editingTopic = null;
        topicFormData = new Topic { Order = lesson.Topics.Count + 1, IsActive = true };
        showTopicForm = true;
    }
    
    private void EditTopic(Topic topic)
    {
        editingTopic = topic;
        topicFormData = new Topic
        {
            Id = topic.Id,
            Name = topic.Name,
            Description = topic.Description,
            Order = topic.Order,
            IsActive = topic.IsActive,
            AudioUrl = topic.AudioUrl
        };
        showTopicForm = true;
    }
    
    private void SaveTopic()
    {
        if (string.IsNullOrWhiteSpace(topicFormData.Name)) return;
        
        if (editingTopic != null)
        {
            editingTopic.Name = topicFormData.Name;
            editingTopic.Description = topicFormData.Description;
            editingTopic.Order = topicFormData.Order;
            editingTopic.IsActive = topicFormData.IsActive;
            editingTopic.AudioUrl = topicFormData.AudioUrl;
        }
        else
        {
            var newTopic = new Topic
            {
                Name = topicFormData.Name,
                Description = topicFormData.Description,
                Order = topicFormData.Order,
                IsActive = topicFormData.IsActive,
                AudioUrl = topicFormData.AudioUrl,
                LessonId = lesson.Id
            };
            lesson.Topics.Add(newTopic);
        }
        
        CancelTopicForm();
    }
    
    private void CancelTopicForm()
    {
        showTopicForm = false;
        editingTopic = null;
        topicFormData = new Topic();
    }

    private void RemoveTopic(Topic topic)
    {
        lesson.Topics.Remove(topic);
        if (selectedTopicId == topic.Id) selectedTopicId = null;
        ReorderItems(lesson.Topics);
    }
    
    private void ToggleTopicDetails(Guid topicId)
    {
        selectedTopicId = selectedTopicId == topicId ? null : topicId;
    }
    
    #endregion

    #region Content Methods
    
    private void QuickAddContent(Topic topic)
    {
        // Open topic details and show add content form
        selectedTopicId = topic.Id;
        ShowAddContentForm(topic);
    }
    
    private void ShowAddContentForm(Topic topic)
    {
        editingContent = null;
        contentFormData = new Content { Order = topic.Contents.Count + 1, IsActive = true };
        showContentFormForTopic = topic.Id;
    }
    
    private void EditContent(Topic topic, Content content)
    {
        editingContent = content;
        contentFormData = new Content
        {
            Id = content.Id,
            Title = content.Title,
            Body = content.Body,
            Order = content.Order,
            IsActive = content.IsActive,
            VideoUrl = content.VideoUrl,
            AudioUrl = content.AudioUrl
        };
        showContentFormForTopic = topic.Id;
    }
    
    private void SaveContent(Topic topic)
    {
        if (string.IsNullOrWhiteSpace(contentFormData.Title)) return;
        
        if (editingContent != null)
        {
            editingContent.Title = contentFormData.Title;
            editingContent.Body = contentFormData.Body;
            editingContent.Order = contentFormData.Order;
            editingContent.IsActive = contentFormData.IsActive;
            editingContent.VideoUrl = contentFormData.VideoUrl;
            editingContent.AudioUrl = contentFormData.AudioUrl;
        }
        else
        {
            var newContent = new Content
            {
                Title = contentFormData.Title,
                Body = contentFormData.Body,
                Order = contentFormData.Order,
                IsActive = contentFormData.IsActive,
                VideoUrl = contentFormData.VideoUrl,
                AudioUrl = contentFormData.AudioUrl,
                TopicId = topic.Id
            };
            topic.Contents.Add(newContent);
        }
        
        CancelContentForm();
    }
    
    private void CancelContentForm()
    {
        showContentFormForTopic = null;
        editingContent = null;
        contentFormData = new Content();
    }
    
    private void RemoveContent(Topic topic, Content content)
    {
        topic.Contents.Remove(content);
        ReorderItems(topic.Contents);
    }
    
    #endregion

    #region Topic Question Methods
    
    private void QuickAddTopicQuestion(Topic topic)
    {
        // Open topic details and show add question form
        selectedTopicId = topic.Id;
        ShowAddTopicQuestionForm(topic);
    }
    
    private void ShowAddTopicQuestionForm(Topic topic)
    {
        editingTopicQuestion = null;
        topicQuestionFormData[topic.Id] = CreateNewQuestion();
        topicQuestionFormData[topic.Id].Order = topic.Questions.Count + 1;
        showQuestionFormForTopic = topic.Id;
    }
    
    private void EditTopicQuestion(Topic topic, Question question)
    {
        editingTopicQuestion = question;
        // Create a copy to avoid modifying original on cancel
        topicQuestionFormData[topic.Id] = CloneQuestion(question);
        showQuestionFormForTopic = topic.Id;
    }
    
    private Question GetTopicQuestionFormData(Topic topic)
    {
        if (!topicQuestionFormData.ContainsKey(topic.Id))
        {
            topicQuestionFormData[topic.Id] = CreateNewQuestion();
        }
        return topicQuestionFormData[topic.Id];
    }
    
    private void SaveTopicQuestion(Topic topic)
    {
        var formData = GetTopicQuestionFormData(topic);
        if (string.IsNullOrWhiteSpace(formData.Text)) return;
        
        formData.TopicId = topic.Id;
        
        if (editingTopicQuestion != null)
        {
            // Copy values from form to original
            CopyQuestionValues(formData, editingTopicQuestion);
        }
        else
        {
            // Add new question
            formData.Order = topic.Questions.Count + 1;
            topic.Questions.Add(formData);
        }
        
        CancelTopicQuestionForm();
    }
    
    private void CancelTopicQuestionForm()
    {
        showQuestionFormForTopic = null;
        editingTopicQuestion = null;
    }
    
    #endregion

    #region Lesson Question Methods
    
    private void ShowAddLessonQuestionForm()
    {
        editingLessonQuestion = null;
        lessonQuestionFormData = CreateNewQuestion();
        lessonQuestionFormData.Order = lesson.Questions.Count + 1;
        showLessonQuestionForm = true;
    }
    
    private void EditLessonQuestion(Question question)
    {
        editingLessonQuestion = question;
        // Create a copy to avoid modifying original on cancel
        lessonQuestionFormData = CloneQuestion(question);
        showLessonQuestionForm = true;
    }
    
    private void SaveLessonQuestion()
    {
        if (string.IsNullOrWhiteSpace(lessonQuestionFormData.Text)) return;
        
        lessonQuestionFormData.LessonId = lesson.Id;
        
        if (editingLessonQuestion != null)
        {
            // Copy values from form to original
            CopyQuestionValues(lessonQuestionFormData, editingLessonQuestion);
        }
        else
        {
            // Add new question
            lessonQuestionFormData.Order = lesson.Questions.Count + 1;
            lesson.Questions.Add(lessonQuestionFormData);
        }
        
        CancelLessonQuestionForm();
    }
    
    private void CancelLessonQuestionForm()
    {
        showLessonQuestionForm = false;
        editingLessonQuestion = null;
        lessonQuestionFormData = CreateNewQuestion();
    }
    
    private void RemoveQuestion(List<Question> questions, Question question)
    {
        questions.Remove(question);
        ReorderItems(questions);
    }
    
    #endregion

    #region Helper Methods
    
    private void ReorderItems<T>(List<T> items) where T : class
    {
        var orderProperty = typeof(T).GetProperty("Order");
        if (orderProperty != null)
        {
            for (int i = 0; i < items.Count; i++)
            {
                orderProperty.SetValue(items[i], i + 1);
            }
        }
    }
    
    private string GetQuestionTypeLabel(QuestionType type) => type switch
    {
        QuestionType.MultipleChoice => "اختيار متعدد",
        QuestionType.TrueFalse => "صح/خطأ",
        QuestionType.FillBlank => "ملء الفراغ",
        QuestionType.Essay => "مقالي",
        _ => "غير محدد"
    };
    
    private Color GetQuestionTypeBadgeColor(QuestionType type) => type switch
    {
        QuestionType.MultipleChoice => Color.Primary,
        QuestionType.TrueFalse => Color.Success,
        QuestionType.FillBlank => Color.Warning,
        QuestionType.Essay => Color.Info,
        _ => Color.Secondary
    };
    
    private Question CloneQuestion(Question original)
    {
        var clone = new Question
        {
            Id = original.Id,
            Text = original.Text,
            Type = original.Type,
            Order = original.Order,
            Points = original.Points,
            IsRequired = original.IsRequired,
            IsActive = original.IsActive,
            AudioUrl = original.AudioUrl,
            VideoUrl = original.VideoUrl,
            ImageUrl = original.ImageUrl,
            Body = original.Body,
            CorrectFeedback = original.CorrectFeedback,
            WrongFeedback = original.WrongFeedback,
            LessonId = original.LessonId,
            TopicId = original.TopicId
        };
        
        foreach (var opt in original.Options)
        {
            clone.Options.Add(new QuestionOption
            {
                Id = opt.Id,
                Text = opt.Text,
                IsCorrect = opt.IsCorrect,
                Order = opt.Order,
                AudioUrl = opt.AudioUrl,
                ImgUrl = opt.ImgUrl,
                QuestionId = opt.QuestionId
            });
        }
        
        return clone;
    }
    
    private void CopyQuestionValues(Question source, Question target)
    {
        target.Text = source.Text;
        target.Type = source.Type;
        target.Order = source.Order;
        target.Points = source.Points;
        target.IsRequired = source.IsRequired;
        target.IsActive = source.IsActive;
        target.AudioUrl = source.AudioUrl;
        target.VideoUrl = source.VideoUrl;
        target.ImageUrl = source.ImageUrl;
        target.Body = source.Body;
        target.CorrectFeedback = source.CorrectFeedback;
        target.WrongFeedback = source.WrongFeedback;
        
        target.Options.Clear();
        foreach (var opt in source.Options)
        {
            target.Options.Add(new QuestionOption
            {
                Id = opt.Id,
                Text = opt.Text,
                IsCorrect = opt.IsCorrect,
                Order = opt.Order,
                AudioUrl = opt.AudioUrl,
                ImgUrl = opt.ImgUrl,
                QuestionId = opt.QuestionId
            });
        }
    }
    
    #endregion

    #region Save Methods
    
    private void SaveLesson()
    {
        if (string.IsNullOrWhiteSpace(lesson.Name)) return;

        if (IsEdit)
        {
            LessonService.Update(lesson);
        }
        else
        {
            LessonService.Add(lesson);
        }

        NavigationManager.NavigateTo("/lessons");
    }

    private void SaveAndAddNew()
    {
        if (string.IsNullOrWhiteSpace(lesson.Name)) return;

        LessonService.Add(lesson);
        lesson = new Lesson();
        selectedTab = "lesson";
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/lessons");
    }
    
    #endregion

    #region Drag & Drop Methods
    
    private DotNetObjectReference<Form>? objRef;
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
        }
        
        // Initialize sortable for topics when they exist
        if (lesson.Topics.Any() && selectedTab == "topics")
        {
            await Task.Delay(100); // Small delay to ensure DOM is ready
            await JSRuntime.InvokeVoidAsync("sortableInterop.initSortable", "topics-sortable", objRef, "OnTopicsReordered", false);
        }
        
        // Initialize sortable for lesson questions
        if (lesson.Questions.Any() && selectedTab == "questions")
        {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("sortableInterop.initSortable", "lesson-questions-sortable", objRef,
"OnLessonQuestionsReordered", false);
        }
        
        // Initialize sortables for expanded topic details (content & questions)
        if (selectedTopicId.HasValue && selectedTab == "topics")
        {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("sortableInterop.initTopicDetailsSortables", selectedTopicId.Value.ToString(), objRef);
        }
    }
    
    [JSInvokable]
    public void OnTopicsReordered(string orderJson)
    {
        var newOrder = System.Text.Json.JsonSerializer.Deserialize<List<OrderItem>>(orderJson);
        if (newOrder != null)
        {
            foreach (var item in newOrder)
            {
                var topic = lesson.Topics.FirstOrDefault(t => t.Id.ToString() == item.Id);
                if (topic != null)
                {
                    topic.Order = item.Order;
                }
            }
            StateHasChanged();
        }
    }
    
    [JSInvokable]
    public void OnLessonQuestionsReordered(string orderJson)
    {
        var newOrder = System.Text.Json.JsonSerializer.Deserialize<List<OrderItem>>(orderJson);
        if (newOrder != null)
        {
            foreach (var item in newOrder)
            {
                var question = lesson.Questions.FirstOrDefault(q => q.Id.ToString() == item.Id);
                if (question != null)
                {
                    question.Order = item.Order;
                }
            }
            StateHasChanged();
        }
    }
    
    [JSInvokable]
    public void OnContentReordered(string orderJson)
    {
        var newOrder = System.Text.Json.JsonSerializer.Deserialize<List<OrderItemWithParent>>(orderJson);
        if (newOrder != null && newOrder.Any())
        {
            var topicId = Guid.Parse(newOrder.First().TopicId);
            var topic = lesson.Topics.FirstOrDefault(t => t.Id == topicId);
            if (topic != null)
            {
                foreach (var item in newOrder)
                {
                    var content = topic.Contents.FirstOrDefault(c => c.Id.ToString() == item.Id);
                    if (content != null)
                    {
                        content.Order = item.Order;
                    }
                }
                StateHasChanged();
            }
        }
    }
    
    [JSInvokable]
    public void OnTopicQuestionsReordered(string orderJson)
    {
        var newOrder = System.Text.Json.JsonSerializer.Deserialize<List<OrderItemWithParent>>(orderJson);
        if (newOrder != null && newOrder.Any())
        {
            var topicId = Guid.Parse(newOrder.First().TopicId);
            var topic = lesson.Topics.FirstOrDefault(t => t.Id == topicId);
            if (topic != null)
            {
                foreach (var item in newOrder)
                {
                    var question = topic.Questions.FirstOrDefault(q => q.Id.ToString() == item.Id);
                    if (question != null)
                    {
                        question.Order = item.Order;
                    }
                }
                StateHasChanged();
            }
        }
    }
    
    public void Dispose()
    {
        objRef?.Dispose();
    }
    
    private class OrderItem
    {
        public string Id { get; set; } = "";
        public int Order { get; set; }
    }
    
    private class OrderItemWithParent : OrderItem
    {
        public string TopicId { get; set; } = "";
    }
    
    #endregion
}
