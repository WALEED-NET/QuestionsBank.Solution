@using QuestionsBank.Models

<div class="card mb-3" style="border-right: 3px solid #f97316;">
    <div class="card-header" style="background: #fff7ed;">
        <div class="d-flex justify-content-between align-items-center">
            <span>
                @if (Index > 0)
                {
                    <span class="badge" style="background: #ffedd5; color: #c2410c;">نشاط @Index</span>
                }
                else
                {
                    <span class="badge" style="background: #ffedd5; color: #c2410c;">
                        <i class="fas @(IsEditMode ? "fa-edit" : "fa-plus") me-1"></i>
                        @(IsEditMode ? "تعديل النشاط" : "نشاط جديد")
                    </span>
                }
            </span>
            @if (!ShowSaveCancel)
            {
                <button type="button" class="btn btn-outline-danger btn-sm" @onclick="OnRemove">
                    <i class="fas fa-trash"></i>
                </button>
            }
            else
            {
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="OnCancel">
                    <i class="fas fa-times"></i>
                </button>
            }
        </div>
    </div>
    <div class="card-body">
        <!-- معلومات النشاط الأساسية -->
        <div class="row g-3 mb-3">
            <div class="col-12 col-md-8">
                <label class="form-label">عنوان النشاط *</label>
                <input type="text" class="form-control" @bind="Question.Text" placeholder="مثال: الاختيار من متعدد" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">نوع النشاط</label>
                <select class="form-select" @bind="questionType">
                    <option value="@QuestionType.MultipleChoice">اختيار متعدد</option>
                    <option value="@QuestionType.TrueFalse">صح/خطأ</option>
                    <option value="@QuestionType.FillBlank">ملء الفراغ</option>
                    <option value="@QuestionType.Essay">مقالي</option>
                </select>
            </div>
        </div>

        <!-- قسم الأسئلة الفرعية -->
        <div class="sub-questions-section border rounded p-3 mb-3" style="background: #fafafa;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="m-0">
                    <i class="fas fa-list-ol me-2 text-primary"></i>
                    الأسئلة الفرعية (Options)
                </h6>
                <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AddSubQuestion">
                    <i class="fas fa-plus me-1"></i>
                    إضافة سؤال
                </button>
            </div>
            
            @if (!Question.Options.Any())
            {
                <div class="alert alert-info mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    اضغط على "إضافة سؤال" لإضافة أسئلة فرعية
                </div>
            }
            else
            {
                @foreach (var (subQuestion, sqIndex) in Question.Options.Select((sq, i) => (sq, i + 1)))
                {
                    <div class="sub-question-card card mb-3 border-start border-primary border-3">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center py-2">
                            <span class="badge bg-primary">@GetQuestionNumber(sqIndex)</span>
                            <button type="button" class="btn btn-outline-danger btn-sm" 
                                    @onclick="@(() => RemoveSubQuestion(subQuestion))">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </div>
                        <div class="card-body">
                            <!-- نص السؤال الفرعي -->
                            <div class="row g-2 mb-3">
                                <div class="col-md-8">
                                    <label class="form-label small text-muted">نص السؤال</label>
                                    <input type="text" class="form-control" @bind="subQuestion.Text" 
                                           placeholder="مثال: أ- الاسم:" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small text-muted">رابط الصوت (اختياري)</label>
                                    <input type="text" class="form-control" @bind="subQuestion.AudioUrl" 
                                           placeholder="رابط الصوت" />
                                </div>
                            </div>

                            <!-- الإجابات -->
                            @if (questionType == QuestionType.MultipleChoice || questionType == QuestionType.TrueFalse)
                            {
                                <div class="answers-section bg-white border rounded p-2">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <small class="text-muted">
                                            <i class="fas fa-check-circle me-1 text-success"></i>
                                            الإجابات (حدد الإجابة الصحيحة)
                                        </small>
                                        @if (questionType == QuestionType.MultipleChoice)
                                        {
                                            <button type="button" class="btn btn-outline-success btn-sm" 
                                                    @onclick="@(() => AddAnswer(subQuestion))">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        }
                                    </div>
                                    
                                    @foreach (var (answer, aIndex) in subQuestion.Answers.Select((a, i) => (a, i + 1)))
                                    {
                                        <div class="answer-row d-flex align-items-center gap-2 mb-2">
                                            <input type="radio" class="form-check-input" 
                                                   name="@($"sq_{subQuestion.Id}")" 
                                                   checked="@answer.IsCorrect"
                                                   @onchange="@(() => SetCorrectAnswer(subQuestion, answer))" />
                                            <span class="badge @(answer.IsCorrect ? "bg-success" : "bg-secondary")">
                                                @GetAnswerLetter(aIndex)
                                            </span>
                                            <input type="text" 
                                                   class="form-control form-control-sm flex-grow-1 @(answer.IsCorrect ? "border-success" : "")"
                                                   @bind="answer.Text" 
                                                   placeholder="@($"الإجابة {GetAnswerLetter(aIndex)}")" />
                                            @if (questionType == QuestionType.MultipleChoice && subQuestion.Answers.Count > 2)
                                            {
                                                <button type="button" class="btn btn-outline-danger btn-sm" 
                                                        @onclick="@(() => RemoveAnswer(subQuestion, answer))">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else if (questionType == QuestionType.FillBlank)
                            {
                                <div class="fill-blank-answer">
                                    <label class="form-label small text-muted">الإجابة الصحيحة</label>
                                    <input type="text" class="form-control" 
                                           value="@(subQuestion.Answers.FirstOrDefault()?.Text ?? "")"
                                           @onchange="@(e => SetFillBlankAnswer(subQuestion, e.Value?.ToString() ?? ""))"
                                           placeholder="أدخل الإجابة الصحيحة" />
                                    <small class="text-muted">استخدم | للفصل بين الإجابات المقبولة</small>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <!-- إعدادات إضافية -->
        <div class="mt-3 pt-3 border-top">
            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <label class="form-label">النقاط</label>
                    <input type="number" class="form-control" @bind="Question.Points" min="1" max="100" />
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label">إجباري</label>
                    <select class="form-select" value="@(Question.IsRequired ? "yes" : "no")" 
                            @onchange="@(e => Question.IsRequired = e.Value?.ToString() == "yes")">
                        <option value="yes">نعم</option>
                        <option value="no">لا</option>
                    </select>
                </div>
            </div>
        </div>
        
        @if (ShowSaveCancel)
        {
            <div class="d-flex justify-content-end gap-2 mt-3 pt-3 border-top">
                <button type="button" class="btn btn-outline-secondary" @onclick="OnCancel">
                    <i class="fas fa-times me-1"></i>
                    إلغاء
                </button>
                <button type="button" class="btn btn-success" @onclick="OnSave">
                    <i class="fas fa-check me-1"></i>
                    @(IsEditMode ? "حفظ التعديلات" : "إضافة")
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public Question Question { get; set; } = new();
    [Parameter] public int Index { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }
    [Parameter] public bool ShowSaveCancel { get; set; } = false;
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsEditMode { get; set; } = false;
    
    private QuestionType questionType
    {
        get => Question.Type;
        set
        {
            if (Question.Type != value)
            {
                Question.Type = value;
                OnTypeChanged(value);
                StateHasChanged();
            }
        }
    }

    protected override void OnParametersSet()
    {
        // إذا لم تكن هناك أسئلة فرعية، أضف واحد افتراضي
        if (!Question.Options.Any())
        {
            AddSubQuestion();
        }
    }
    
    private void OnTypeChanged(QuestionType newType)
    {
        // تحديث الإجابات لكل سؤال فرعي حسب النوع الجديد
        foreach (var subQuestion in Question.Options)
        {
            InitializeAnswersForSubQuestion(subQuestion, newType);
        }
    }
    
    private void InitializeAnswersForSubQuestion(QuestionOption subQuestion, QuestionType type)
    {
        subQuestion.Answers.Clear();
        
        switch (type)
        {
            case QuestionType.MultipleChoice:
                // 4 إجابات افتراضية
                subQuestion.Answers.Add(new Answer { Text = "", Order = 1, OptionId = subQuestion.Id });
                subQuestion.Answers.Add(new Answer { Text = "", Order = 2, OptionId = subQuestion.Id });
                subQuestion.Answers.Add(new Answer { Text = "", Order = 3, OptionId = subQuestion.Id });
                break;
                
            case QuestionType.TrueFalse:
                // صح/خطأ
                subQuestion.Answers.Add(new Answer { Text = "صحيح", Order = 1, IsCorrect = true, OptionId = subQuestion.Id });
                subQuestion.Answers.Add(new Answer { Text = "خطأ", Order = 2, IsCorrect = false, OptionId = subQuestion.Id });
                break;
                
            case QuestionType.FillBlank:
                // إجابة واحدة للملء
                subQuestion.Answers.Add(new Answer { Text = "", Order = 1, IsCorrect = true, OptionId = subQuestion.Id });
                break;
        }
    }

    private string GetQuestionNumber(int index) => $"سؤال {index}";
    
    private string GetAnswerLetter(int index) => index switch
    {
        1 => "أ",
        2 => "ب",
        3 => "ج",
        4 => "د",
        5 => "هـ",
        6 => "و",
        _ => index.ToString()
    };

    private void AddSubQuestion()
    {
        var newSubQuestion = new QuestionOption
        {
            Order = Question.Options.Count + 1,
            ActivityId = Question.Id
        };
        InitializeAnswersForSubQuestion(newSubQuestion, Question.Type);
        Question.Options.Add(newSubQuestion);
    }
    
    private void RemoveSubQuestion(QuestionOption subQuestion)
    {
        Question.Options.Remove(subQuestion);
        // إعادة ترتيب
        for (int i = 0; i < Question.Options.Count; i++)
        {
            Question.Options[i].Order = i + 1;
        }
    }

    private void SetCorrectAnswer(QuestionOption subQuestion, Answer answer)
    {
        // إجابة صحيحة واحدة فقط لكل سؤال فرعي
        foreach (var ans in subQuestion.Answers)
        {
            ans.IsCorrect = false;
        }
        answer.IsCorrect = true;
    }

    private void AddAnswer(QuestionOption subQuestion)
    {
        if (subQuestion.Answers.Count < 6)
        {
            subQuestion.Answers.Add(new Answer
            {
                Order = subQuestion.Answers.Count + 1,
                OptionId = subQuestion.Id
            });
        }
    }

    private void RemoveAnswer(QuestionOption subQuestion, Answer answer)
    {
        subQuestion.Answers.Remove(answer);
        for (int i = 0; i < subQuestion.Answers.Count; i++)
        {
            subQuestion.Answers[i].Order = i + 1;
        }
    }
    
    private void SetFillBlankAnswer(QuestionOption subQuestion, string value)
    {
        if (subQuestion.Answers.Any())
        {
            subQuestion.Answers[0].Text = value;
        }
        else
        {
            subQuestion.Answers.Add(new Answer { Text = value, IsCorrect = true, OptionId = subQuestion.Id });
        }
    }
    
    /// <summary>
    /// تحضير البيانات قبل الحفظ
    /// </summary>
    public void PrepareForSave()
    {
        // ربط كل سؤال فرعي بالنشاط
        foreach (var subQuestion in Question.Options)
        {
            subQuestion.ActivityId = Question.Id;
            foreach (var answer in subQuestion.Answers)
            {
                answer.OptionId = subQuestion.Id;
            }
        }
    }
}
